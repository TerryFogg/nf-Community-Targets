{
  "version": 4,
  "configurePresets": [
    {
      "name": "LOCAL_SOURCES",
      "description": "Configuration for setting up locations where external source repositories have been copied to local disk",
      "hidden": true,
      "cacheVariables": {
        "THREADX_SOURCE": "C:/nftools/ThreadX",
        "NETXDUO_SOURCE_FOLDER": "C:/nftools/NetxDuo",
        "STM32H7_CUBE_SOURCE": "C:/nftools/STM32CubeH7",
        "STM32U5_CUBE_SOURCE": "C:/nftools/STM32CubeU5",
        "PICO_SDK_SOURCE": "C:/nftools/pico-sdk"
      }
    },
    {
      "name": "DEBUG",
      "description": "This is non-optimized and contains all the debug symbols",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "RELEASE",
      "description": "This is optimized for speed without debugging symbols and asserts disabled.",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "RELEASE_WITH_DEBUG_INFO",
      "description": "This provides optimized code and includes debug symbols but disabled asserts",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "RELEASE_MINIMUM_SIZE",
      "description": "This is the same as Release but optimized for a small binary size instead of speed",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel"
      }
    },
    {
      "name": "FULL_MATHEMATICS",
      "description": "Configuration for setting up what hardware/software support for mathematics",
      "hidden": true,
      "cacheVariables": {
        "NF_FEATURE_LIGHT_MATH": "false",
        "DP_FLOATINGPOINT": "true"
      }
    },
    {
      "name": "GCC_ARM_COMMON_BUILD",
      "inherits": "general-preset",
      "description": "Configuration common to all arm series processors",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "RTOS": "ThreadX",
        "COMMUNITY_TARGET": "ThreadX",
        "CMAKE_SYSTEM_NAME": "Generic",
        "CMAKE_SYSTEM_PROCESSOR": "ARM",
        "CMAKE_TRY_COMPILE_TARGET_TYPE": "STATIC_LIBRARY",
        "CMAKE_C_COMPILER": "C:/nftools/GNU_Tools_ARM_Embedded/12.3.rel1/bin/arm-none-eabi-gcc.exe",
        "CMAKE_CXX_COMPILER": "C:/nftools/GNU_Tools_ARM_Embedded/12.3.rel1/bin/arm-none-eabi-g++.exe",
        "CMAKE_ASM_COMPILER": "C:/nftools/GNU_Tools_ARM_Embedded/12.3.rel1/bin/arm-none-eabi-gcc.exe",
        "CMAKE_LINKER": "C:/nftools/GNU_Tools_ARM_Embedded/12.3.rel1/bin/arm-none-eabi-gcc.exe",
        "CMAKE_SIZE_UTIL": "C:/nftools/GNU_Tools_ARM_Embedded/12.3.rel1/bin/arm-none-eabi-size.exe",
        "CMAKE_OBJCOPY": "C:/nftools/GNU_Tools_ARM_Embedded/12.3.rel1/bin/arm-none-eabi-objcopy.exe",
        "CMAKE_OBJDUMP": "C:/nftools/GNU_Tools_ARM_Embedded/12.3.rel1/bin/arm-none-eabi-objdump.exe",
        "CMAKE_NM_UTIL": "C:/nftools/GNU_Tools_ARM_Embedded/12.3.rel1/bin/arm-none-eabi-nm.exe",
        "CMAKE_AR": "C:/nftools/GNU_Tools_ARM_Embedded/12.3.rel1/bin/arm-none-eabi-gcc-ar",
        "CMAKE_RANLIB": "C:/nftools/GNU_Tools_ARM_Embedded/12.3.rel1/bin/arm-none-eabi-ranlib.exe"
      }
    },
    {
      "name": "STM32H735G_DK",
      "description": "Configuration for the STM32H735G_DK (Cortex M-7) discovery board from STMicroelectronics",
      "inherits": [
        "LOCAL_SOURCES",
        "GCC_ARM_COMMON_BUILD",
        "FULL_MATHEMATICS"
      ],
      "cacheVariables": {
        "TARGET_BOARD": "STM32H735G_DK",
        "TARGET_FAMILY": "STM32H7",
        "TARGET_SERIES": "STM32H735xx",
        "ARM_PROCESSOR": "Cortex-M7",
        "BUILD_VERSION": "1.0.0.0",
        "DISPLAY_CONTROLLER": "RK043FN48H_VideoMode.cpp",
        "DISPLAY_INTERFACE": "LTDC_DMA2D_To_Video.cpp",
        "INFOSTRING": "Built with ThreadX  6.1.12",
        "GRAPHICS_SUPPORT": "TRUE",
        "RANDOM_NUMBER_GENERATOR": "TRUE"
      },
      "hidden": false
    },
